# Microsoft Graph (Outlook) — register an app at https://portal.azure.com
# Azure AD > App registrations > New registration > Accounts in this org directory
# Add delegated permission: Microsoft Graph > Mail.Read   (read-only by design)
AZURE_CLIENT_ID=your-app-client-id
AZURE_TENANT_ID=common

# Direct IMAP (Gmail / any provider) — no Outlook, no Azure
#   Gmail: enable IMAP, create an App Password (Google Account > Security > App passwords)
IMAP_HOST=imap.gmail.com
IMAP_USER=you@gmail.com
IMAP_PASS=your-16-char-app-password

# Local Gemma via Ollama
OLLAMA_HOST=http://localhost:11434
GEMMA_MODEL=gemma3:4b

# Engine tuning
CONFIDENCE_THRESHOLD=0.6      # below this → needs_review, never auto-acted
DB_PATH=inboxzero.db
